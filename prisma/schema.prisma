generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── SHOP ────────────────────────────────────────────────────────────────────
model Shop {
  id               String          @id @default(cuid())
  name             String?
  email            String?         @unique
  password         String?
  phone            String          @unique
  businessType     String          @default("RESTAURANT") // RESTAURANT | RETAIL | SERVICE | MEDICAL | CUSTOM
  category         String?         @default("Restaurant") 
  address          String?
  gstNumber        String?
  
  // Invoice Configuration
  invoicePrefix    String          @default("BILL")
  invoiceCounter   Int             @default(1000)
  invoiceResetCycle String         @default("NEVER") // NEVER | MONTHLY | YEARLY
  lastResetDate    DateTime?
  
  autoSendWA       Boolean         @default(true)
  autoSendEmail    Boolean         @default(true)
  
  // Branding & UI Config
  primaryColor     String          @default("#0A0A0A")
  secondaryColor   String          @default("#D4AF37")
  logoUrl          String?
  footerText       String?         @default("Thank you for visiting!")
  enabledModules   String          @default("[\"billing\", \"inventory\"]") // JSON array of feature keys
  activeTemplateId String?         @default("modern-minimal")
  
  onboardingStep   Int             @default(0)
  onboardedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  bills            Bill[]
  customers        ShopCustomer[]
  messages         Message[]
  campaigns        EmailCampaign[]
  offers           Offer[]
  menuItems        MenuItem[]
  tables           Table[]
  kitchenOrders    KitchenOrder[]
  auditLogs        AuditLog[]
  templates        ReceiptTemplate[]

  @@index([phone])
}

// ─── RECEIPT TEMPLATES ────────────────────────────────────────────────────────
model ReceiptTemplate {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  name        String   // "Modern Minimal", "Classic Retail", etc.
  version     Int      @default(1)
  config      String   @default("{}") // JSON for layout specific overrides
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  action      String   // EDIT_BILL | REFUND | CANCEL_ORDER | CONFIG_CHANGE
  entityType  String   // Bill | MenuItem | Shop
  entityId    String
  userId      String?
  description String
  metadata    String?  @default("{}") // JSON snapshot of changes
  createdAt   DateTime @default(now())

  @@index([shopId, createdAt])
}

// ─── CUSTOMER ────────────────────────────────────────────────────────────────
model Customer {
  id        String          @id @default(cuid())
  name      String?
  phone     String?         @unique
  email     String?         @unique
  optedIn   Boolean         @default(false)
  createdAt DateTime        @default(now())
  
  shops     ShopCustomer[]
  bills     Bill[]
  messages  Message[]
  optIns    OptIn[]

  @@index([phone])
}

// ─── SHOP-CUSTOMER RELATIONSHIP ──────────────────────────────────────────────
model ShopCustomer {
  shopId     String
  customerId String
  totalSpent Float    @default(0)
  visitCount Int      @default(0)
  lastVisit  DateTime @default(now())

  shop     Shop     @relation(fields: [shopId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@id([shopId, customerId])
}

// ─── MENU ITEM ───────────────────────────────────────────────────────────────
model MenuItem {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  name        String
  price       Float                    // ₹
  category    String                   // "Starters" | "Mains" | "Drinks" | "Desserts" | custom
  description String?
  isAvailable Boolean  @default(true)  // toggle to mark out-of-stock
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, isAvailable])
}

// ─── TABLE ───────────────────────────────────────────────────────────────────
model Table {
  id       String  @id @default(cuid())
  shopId   String
  shop     Shop    @relation(fields: [shopId], references: [id])
  number   Int                           // Table 1, Table 2...
  label    String?                       // "Window seat", "VIP", etc.
  capacity Int     @default(4)
  status   String  @default("empty")    // empty | occupied | bill-requested
  bills    Bill[]
}

// ─── BILL ────────────────────────────────────────────────────────────────────
model Bill {
  id            String     @id @default(cuid())
  invoiceNum    String?    @unique // e.g. INV-1001
  shopId        String
  shop          Shop       @relation(fields: [shopId], references: [id])
  customerId    String?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  tableId       String?
  table         Table?     @relation(fields: [tableId], references: [id])
  tableNum      String?
  cashierName   String?
  
  customerPhone String?
  customerEmail String?
  
  // Financials
  subtotal      Float      @default(0)
  taxRate       Float      @default(0)
  taxAmount     Float      @default(0)
  discountAmount Float     @default(0)
  tipAmount     Float      @default(0)
  total         Float
  
  category      String     // Restaurant | Retail | etc
  paymentMethod String?    @default("UPI") // Cash | UPI | Card
  status        String     @default("paid") // paid | pending | cancelled
  metadata      String?    @default("{}") // JSON for store-specific data
  
  items         BillItem[]
  kitchenOrder  KitchenOrder?
  createdAt     DateTime   @default(now())

  @@index([customerId, createdAt])
  @@index([shopId, createdAt])
  @@index([invoiceNum])
}

// ─── BILL ITEM ────────────────────────────────────────────────────────────────
model BillItem {
  id        String   @id @default(cuid())
  billId    String
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  quantity  Int
  modifiers String?  @default("[]") // JSON for add-ons like "Extra Cheese"
  createdAt DateTime @default(now())
}

// ─── KITCHEN ORDER ───────────────────────────────────────────────────────────
model KitchenOrder {
  id                String             @id @default(cuid())
  billId            String             @unique
  bill              Bill               @relation(fields: [billId], references: [id])
  shopId            String
  shop              Shop               @relation(fields: [shopId], references: [id])
  tableNum          Int?
  items             KitchenOrderItem[]
  status            String             @default("pending") // pending | preparing | ready | served
  priority          String             @default("normal")  // normal | rush
  estimatedMinutes  Int?
  preparingStartedAt DateTime?
  readyAt           DateTime?
  servedAt          DateTime?
  waNotified        Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([shopId, status])
}

model KitchenOrderItem {
  id          String    @id @default(cuid())
  orderId     String
  order       KitchenOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name        String
  qty         Int
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

// ─── MESSAGE (Shop → Customer chat) ──────────────────────────────────────────
model Message {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  content     String
  isFromStore Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── EMAIL CAMPAIGN ───────────────────────────────────────────────────────────
model EmailCampaign {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  name        String
  subject     String
  body        String
  sentToCount Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── OTP TOKEN ────────────────────────────────────────────────────────────────
model OtpToken {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─── OFFER BROADCAST ──────────────────────────────────────────────────────────
model Offer {
  id            String           @id @default(cuid())
  shopId        String
  shop          Shop             @relation(fields: [shopId], references: [id])
  title         String
  message       String
  discountType  String?
  discountValue Float?
  validUntil    DateTime?
  audienceType  String
  status        String           @default("pending")
  theme         String           @default("dark")
  imageMode     String           @default("generated") // generated | custom
  imageUrl      String?
  imageGenUrl   String?
  scheduledAt   DateTime?
  sentAt        DateTime?
  createdAt     DateTime         @default(now())
  recipients    OfferRecipient[]

  @@index([shopId, createdAt])
}

model OfferRecipient {
  id         String    @id @default(cuid())
  offerId    String
  offer      Offer     @relation(fields: [offerId], references: [id])
  customerId String?
  phone      String
  email      String?
  status     String    @default("queued")
  sentAt     DateTime?
  error      String?

  @@index([offerId, status])
}

// ─── PER-SHOP OPT-IN ─────────────────────────────────────────────────────────
model OptIn {
  id         String   @id @default(cuid())
  customerId String
  shopId     String
  optedIn    Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, shopId])
  @@index([shopId, optedIn])
}

// ─── NOTIFICATION SYSTEM ─────────────────────────────────────────────────────
model Notification {
  id         String   @id @default(cuid())
  userId     String   // customerId or shopId
  userType   String   // "customer" | "shop"
  type       String   // NEW_BILL | OFFER_RECEIVED | etc.
  title      String
  body       String
  data       Json?    // { billId, offerId, amount } etc.
  read       Boolean  @default(false)
  readAt     DateTime?
  channel    String   // "inapp" | "email" | "whatsapp" | "push"
  sentAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  emailEnabled    Boolean @default(true)
  whatsappEnabled Boolean @default(true)
  pushEnabled     Boolean @default(false)
  offerAlerts     Boolean @default(true)
}
