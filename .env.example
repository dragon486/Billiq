# BILLIQ Environment Variables — Copy to .env and fill in real values
DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET=generate_32_random_chars_here
NEXTAUTH_URL=http://localhost:3000

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16char_google_app_password
EMAIL_FROM="BILLIQ <your_gmail@gmail.com>"

# WhatsApp Business API (Meta) — Optional, leave blank to use wa.me links
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# App URL (set to production domain in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
